{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "cleanUrls": true,
    "version": 2,
    "public": true,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/server.js"
        },
        {
            "src": "/$",
            "dest": "/public/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/dashboard",
            "destination": "/public/pages/dashboard.html"
        }
    ]
}