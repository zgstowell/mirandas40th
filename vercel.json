{
    "version": 2,
    "functions": {
        "api/index.js": {
            "runtime": "@vercel/node"
        }
    },
    "routes": [
        {
            "src": "/api(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/pages/(.*)",
            "dest": "/pages/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/js/$1"
        },
        {
            "src": "/(?!api)(.*)",
            "dest": "/$1"
        }
    ]
}